# Environment Variables for English Teacher Dashboard
# Copy this file to .env and fill in your values

# Supabase (обязательно)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-key

# Notion (опционально — для синхронизации расписания)
NOTION_TOKEN=ntn_your_notion_token
NOTION_DB_ID=your_notion_database_id

# OpenAI (опционально — если используете GPT-4o)
OPENAI_API_KEY=sk-your-openai-key

# Telegram Bot (обязательно)
TELEGRAM_BOT_TOKEN=1234567890:AAH...
TEACHER_TELEGRAM_ID=123456789

# Timezone для Notion (по умолчанию Казахстан)
TEACHER_TIMEZONE=+05:00
